{
  "name": "mod-agent-for-discord",
  "version": "0.1.0",
  "description": "LLM-powered, context-aware Discord moderation agent. Regex pre-filter, Haiku classification, Opus escalation, human-in-the-loop. Never auto-bans.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "discord",
    "moderation",
    "bot",
    "llm",
    "claude",
    "anthropic",
    "automod",
    "context-aware"
  ]
}
